datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // hashed dengan bcryptjs
  createdAt DateTime @default(now())
}

model Laptop {
  id          Int      @id @default(autoincrement())
  name        String
  brand       String
  cpuScore    Int      // skala 1–10, representasi performa CPU
  ramGb       Int      // dalam GB
  storageGb   Int      // dalam GB
  price       Int      // dalam rupiah
  imageUrl    String?
  description String   // deskripsi laptop lengkap
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
